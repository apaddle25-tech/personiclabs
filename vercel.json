{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/assessment",
      "destination": "/personic-soundtrack-assessment.html",
      "permanent": true
    },
    {
      "source": "/report",
      "destination": "/personic-results-report-export.html",
      "permanent": true
    },
    {
      "source": "/personic-soundtrack",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/personic-soundtrack-standalone.html",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/soundtrack-assessment",
      "destination": "/personic-soundtrack-assessment.html",
      "permanent": true
    },
    {
      "source": "/acoustic-genome",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/acoustic-genome-standalone.html",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/compass",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/personic-compass",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/personic-compass-standalone.html",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/compass-assessment",
      "destination": "/personic-soundtrack-assessment.html",
      "permanent": true
    },
    {
      "source": "/prism",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/personic-prism",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/personic-prism-standalone.html",
      "destination": "/soundtrack",
      "permanent": true
    },
    {
      "source": "/prism-assessment",
      "destination": "/personic-soundtrack-assessment.html",
      "permanent": true
    },
    {
      "source": "/wavelength-how-it-works.html",
      "destination": "/how-it-works",
      "permanent": true
    },
    {
      "source": "/wavelength",
      "destination": "/teams",
      "permanent": true
    },
    {
      "source": "/work",
      "destination": "/teams",
      "permanent": true
    },
    {
      "source": "/enterprise",
      "destination": "/teams",
      "permanent": true
    },
    {
      "source": "/enterprise-standalone.html",
      "destination": "/teams",
      "permanent": true
    },
    {
      "source": "/wavelength-standalone.html",
      "destination": "/teams",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about-us",
      "permanent": true
